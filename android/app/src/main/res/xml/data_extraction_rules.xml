<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) 的备份规则。
  cloud-backup：跨设备 / 卸载重装恢复
  device-transfer：换新机 D2D 传输
  统一允许 DB、文档目录、SharedPrefs；排除 FlutterSecureStorage（本机 keystore 加密，没意义）。
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="."/>
        <include domain="file" path="."/>
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="FlutterSecureStorage.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="."/>
        <include domain="file" path="."/>
        <include domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
